@page "/auth/reset-password"
@attribute [AllowAnonymous]
@inject NavigationManager Nav

<PageTitle>New password</PageTitle>

<div class="container" style="max-width:400px;margin-top:80px">
    <h2 class="mb-4">New password</h2>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (string.IsNullOrWhiteSpace(_token))
    {
        <div class="alert alert-warning">Invalid or expired link.</div>
    }
    else
    {
        <form method="post" action="/auth/reset-password">
            <input type="hidden" name="token" value="@_token" />
            <div class="mb-3">
                <label class="form-label">New password <small class="text-muted">(min. 6 characters)</small></label>
                <input type="password" name="password" class="form-control" required autocomplete="new-password" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Reset password</button>
        </form>
    }

    <div class="mt-3 text-center">
        <a href="/auth/login">Back to login</a>
    </div>
</div>

@code {
    private string? _token;
    private string? _error;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _token = query.TryGetValue("token", out var t) ? t.ToString() : null;
        _error = query.TryGetValue("error", out var e) ? e.ToString() : null;
    }
}
