@namespace Jebi.Web.Shared
@using Jebi.Common.Features.Dtos.Model.Shared

@if (Completeness is not null)
{
    <div class="card border-0 jebi-completeness-card mb-3">
        <div class="card-body p-3">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                <div class="fw-semibold">@Title</div>
                <div class="d-inline-flex align-items-center">
                    <span class="@JebiCompletenessDisplay.GetBadgeClass(Completeness)">
                        @JebiCompletenessDisplay.GetBadgeLabel(Completeness)
                    </span>
                </div>
            </div>

            @if (hasDetails)
            {
                <details class="jebi-completeness-details" open="@DetailsOpenByDefault">
                    <summary class="jebi-completeness-details__summary">Details</summary>
                    <div class="jebi-completeness-details__body">
                        @if (!string.IsNullOrWhiteSpace(Completeness.Summary))
                        {
                            <div class="small text-muted mb-2">@Completeness.Summary</div>
                        }

                        @if (items.Count > 0)
                        {
                            <ul class="small mb-0 ps-3">
                                @foreach (var item in items)
                                {
                                    <li class="@JebiCompletenessDisplay.GetItemClass(item)">
                                        <span class="@JebiCompletenessDisplay.GetItemPrefixClass(item)">@JebiCompletenessDisplay.GetItemPrefix(item)</span>
                                        <span class="fw-semibold">@JebiCompletenessDisplay.GetLabel(item):</span> @JebiCompletenessDisplay.GetMessage(item)
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </details>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "Completeness";
    [Parameter] public CompletenessReportDto? Completeness { get; set; }
    [Parameter] public bool DetailsOpenByDefault { get; set; } = true;

    private IReadOnlyList<object> items => Completeness?.Items.Cast<object>().ToList() ?? [];
    private bool hasDetails => !string.IsNullOrWhiteSpace(Completeness?.Summary) || items.Count > 0;
}
