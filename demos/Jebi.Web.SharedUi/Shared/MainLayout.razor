@inherits LayoutComponentBase
@inject Microsoft.Extensions.Hosting.IHostEnvironment HostEnvironment
@inject IJSRuntime Js
	
<PageTitle>Jebi</PageTitle>

<div class="jebi-app-shell">
    <header class="jebi-global-topbar">
        <div class="jebi-global-topbar__brand-area">
            <button title="Navigation menu"
                    type="button"
                    class="navbar-toggler jebi-global-topbar__toggle"
                    @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="jebi-global-brand-lockup">
                <a class="jebi-global-brand" href="">
                    <img class="jebi-global-brand-logo"
                         src="/_content/Jebi.Web.SharedUi/branding/jebi/logos/jebi-logo-primary-transparent.png"
                         alt="Jebi logo" />
                </a>
                <div class="jebi-global-brand-acronym">JSON Entity Binding Ingestion</div>
            </div>
        </div>

        <div class="jebi-main-topbar__actions">
            <a class="jebi-main-topbar__link"
               href="https://learn.microsoft.com/aspnet/core/"
               target="_blank"
               rel="noreferrer">
                About
            </a>
            <button type="button" class="jebi-main-topbar__theme"
                    @onclick="ToggleThemeAsync"
                    title="Toggle dark mode">
                @(_isDarkTheme ? "Light mode" : "Dark mode")
            </button>
        </div>
    </header>

    <div class="page">
        <div class="sidebar @(_collapseNavMenu ? "sidebar--mobile-collapsed" : null)">
            <NavMenu />
        </div>

        <main>
            <article class="content jebi-main-content">
                <ErrorToast />
                @Body
            </article>
        </main>
    </div>
</div>

@code {
    private bool _isDarkTheme;
    private bool _themeInitialized;
    private bool _collapseNavMenu = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _themeInitialized)
            return;

        try
        {
            _isDarkTheme = await Js.InvokeAsync<bool>("jebiTheme.get");
            _themeInitialized = true;
            StateHasChanged();
        }
        catch (InvalidOperationException)
        {
            // JS interop is not available during prerendering.
        }
    }

    private async Task ToggleThemeAsync()
    {
        _isDarkTheme = await Js.InvokeAsync<bool>("jebiTheme.toggle");
    }

    private void ToggleNavMenu()
    {
        _collapseNavMenu = !_collapseNavMenu;
    }
}
