{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "customer",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "customerId": { "type": "string" },
    "name":       { "type": "string" },
    "age":        { "type": "integer", "minimum": 0 },
    "email":      { "type": "string", "format": "email" },
    "address": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "street": { "type": "string" },
        "city":   { "type": "string" },
        "zip":    { "type": "string" }
      }
    }
  },
  "required": ["customerId"]
}