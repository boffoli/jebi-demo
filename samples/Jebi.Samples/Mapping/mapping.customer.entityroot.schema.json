{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SampleSchema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "customerId": { "type": "string" },
        "name":       { "type": "string" },
        "age":        { "type": "integer", "minimum": 0 },
        "email":      { "type": "string", "format": "email" }
      },
      "required": ["customerId"]
    }
  },
  "required": ["customer"]
}